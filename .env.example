VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Shared trainer account email(s). Must match a user in Supabase Auth + app_trainers table.
# Password is NOT stored here — create it in Supabase Auth and share with trainers.
VITE_TRAINER_EMAILS=trainer@learnerspoint.com
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional — default is claude-sonnet-4-6 (do not use retired claude-3-opus-20240229)
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional — increase output budget for long prompts (default 8000)
ANTHROPIC_MAX_TOKENS=8000
